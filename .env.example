# Copy to .env.local and fill in the keys you have.
# All are optional — the app falls back to a simulator if none are set.

# Primary source: Real Google Flights data + 60-day price history
# Free 100-search trial: https://serpapi.com/users/sign_up
SERPAPI_KEY=

# Fallback 1: Real aggregated price data from Aviasales partners
# Free: https://travelpayouts.com (sign up, connect Aviasales program)
TRAVELPAYOUTS_TOKEN=

# Fallback 2: Duffel test-mode sandbox (fake but realistic shape)
# Free: https://app.duffel.com → Developers → Access tokens (read/write, test env)
DUFFEL_API_TOKEN=
